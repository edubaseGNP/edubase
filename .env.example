SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=edubase
DB_USER=edubase
DB_PASSWORD=edubase_secret
DB_HOST=db
DB_PORT=5432

REDIS_URL=redis://redis:6379/0

# Google OAuth (vyplnit v Kroku 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Volitelné: omezení přihlášení na školní doménu (např. skola.cz)
GOOGLE_ALLOWED_DOMAIN=

# OCR vylepšení (Tesseract, bez API)
OCR_PDF_DPI=300
OCR_LANG=ces+eng

# AI backend pro Vision OCR + budoucí funkce (shrnutí, testy, …)
# Možnosti: none | google | anthropic | ollama
AI_BACKEND=none

# Google Gemini – free tier 1 500 req/den, pak ~0.01 Kč/obr
# AI_BACKEND=google
# GOOGLE_AI_API_KEY=AIza...

# Anthropic Claude – nejlepší kvalita CZ, ~0.11 Kč/obr
# AI_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama lokálně na Proxmox – ZDARMA, data neopustí školu
# AI_BACKEND=ollama
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_VISION_MODEL=llama3.2-vision
# OLLAMA_TEXT_MODEL=llama3.1

# Nastavení pro produkci
# SECURE_SSL_REDIRECT=True
# NPM_BIN_PATH=/usr/bin/npm

# Sentry error tracking (nepovinné – ponechte prázdné pro vypnutí)
SENTRY_DSN=

# Celery Flower monitoring (http://server:5555)
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-in-production
